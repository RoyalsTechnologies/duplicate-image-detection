# Application configuration
APP_NAME=did-backend-api
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://did:did@postgres:5432/did
REDIS_URL=redis://redis:6379/0
ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12,192.168.65.0/24
# Loopback only: Docker bridge (172.x) is allowed via ALLOWED_IPS, not trusted for X-Forwarded-For
TRUSTED_PROXY_IPS=127.0.0.1,::1
LOCAL_STORAGE_DIR=/app/uploads
PUBLIC_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
PORT=8000
# S3 storage configuration
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# Computer vision configuration
CV_PROVIDER=local
CV_DEVICE=cpu
CV_EMBEDDING_MODEL=ViT-B-32
CV_EMBEDDING_PRETRAINED=openai
CV_CACHE_DIR=/var/cache/did-backend-api
CV_YOLO_MODEL=/var/cache/did-backend-api/yolo11n.pt
HF_HOME=/var/cache/did-backend-api/huggingface
HUGGINGFACE_HUB_CACHE=/var/cache/did-backend-api/huggingface/hub
YOLO_CONFIG_DIR=/var/cache/did-backend-api/ultralytics
CV_YOLO_CONFIDENCE=0.25
# Reject uploads that do not appear to show an environmental or public concern
CV_REJECT_IRRELEVANT_IMAGES=true
CV_RELEVANCE_THRESHOLD=0.15
CV_RELEVANCE_MIN_DETECTION_CONFIDENCE=0.25
# Docker build only (set when CV_PROVIDER needs optional deps): cv-embedding | cv-yolo | cv
CV_EXTRAS=
# When CV_EXTRAS is set, use runtime-cv target (reuses cached PyTorch layer in Dockerfile)
# DOCKER_BUILD_TARGET=runtime-cv

# Duplicate detection configuration

DUPLICATE_DISTANCE_METERS=100
DUPLICATE_TIME_WINDOW_HOURS=720
DUPLICATE_SIMILARITY_THRESHOLD=0.86
POSSIBLE_DUPLICATE_SIMILARITY_THRESHOLD=0.68
PERCEPTUAL_HASH_HIGH_SIMILARITY=0.92
PERCEPTUAL_HASH_POSSIBLE_SIMILARITY=0.75
MAX_UPLOAD_SIZE_MB=10
UPLOAD_RATE_LIMIT_PER_MINUTE=20
